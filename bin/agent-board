</script></body></html>"""


def cmd_serve(args):
    import http.server
    import glob as _glob
    port = int(args[0]) if args and args[0].lstrip("-").isdigit() else 7900

    def snapshot():
        sessions = []
        for p in _glob.glob(os.path.join(BOARD, "*.md")):
            if os.path.basename(p).startswith("_"):
                continue
            try:
                fm, _ = read_note(p)
            except Exception:
                continue
            if fm.get("status") != "active":
                continue
            try:
                idle = int((time.time() - os.path.getmtime(p)) / 60)
            except Exception:
                idle = 0
            sessions.append({"session": fm.get("session", ""), "repo": fm.get("repo", ""),
                             "worktree": fm.get("worktree", ""), "task": fm.get("task", ""),
                             "claims": fm.get("claims", []), "idle": idle})
        sessions.sort(key=lambda s: (s["repo"], s["session"]))
        msgs = []
        try:
            with open(msg_store(BOARD)) as f:
                for line in f:
                    line = line.strip()
                    if line:
                        try:
                            msgs.append(json.loads(line))
                        except Exception:
                            pass
        except FileNotFoundError:
            pass
        return {"sessions": sessions, "messages": msgs[-60:],
                "generated": time.strftime("%H:%M:%S")}

    class H(http.server.BaseHTTPRequestHandler):
        def log_message(self, *a):
            pass

        def _send(self, body, ctype):
            self.send_response(200)
            self.send_header("Content-Type", ctype)
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)

        def do_GET(self):
            if self.path.startswith("/data"):
                self._send(json.dumps(snapshot()).encode(), "application/json")
            else:
                self._send(PAGE.encode(), "text/html; charset=utf-8")

    try:
        httpd = http.server.ThreadingHTTPServer(("127.0.0.1", port), H)
    except OSError as e:
        sys.exit(f"agent-board serve: can't bind port {port} ({e}). Try a different port: agent-board serve 7901")
    print(f"agent-board dashboard → http://127.0.0.1:{port}   (Ctrl-C to stop)")
    print(f"board: {BOARD}")
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print("\\nstopped.")


CMDS = {"task": cmd_task, "claim": cmd_claim, "release": cmd_release,
        "note": cmd_note, "check": cmd_check, "who": cmd_who, "where": cmd_where,
        "msg": cmd_msg, "inbox": cmd_inbox, "serve": cmd_serve}


def main():
    if len(sys.argv) < 2 or sys.argv[1] not in CMDS:
        sys.exit(__doc__)
    CMDS[sys.argv[1]](sys.argv[2:])


if __name__ == "__main__":
    main()
