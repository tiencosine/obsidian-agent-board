#!/usr/bin/env python3
"""agent-board — a running Claude Code session updates its own board note.

Resolves "my note" from the cwd->session pointer written by agent-board-hook,
so just run it from inside your session's working directory.

  agent-board task "<one line>"          set what you're doing
  agent-board claim <path> [<path>...]   stake files you'll edit (warns on conflict)
  agent-board release <path> [...]       drop claims
  agent-board note "<text>"              append a timestamped log line to your note
  agent-board check <path>               who else (live) claims this path?
  agent-board who                        text view of all active sessions
  agent-board where                      print your note path + the board dir
  agent-board msg <session|all> "<text>" message another session (or everyone)
  agent-board inbox                      read messages addressed to you
  agent-board serve [port]               live web dashboard (default http://127.0.0.1:7900)

Config: ~/.config/obsidian-agent-board/config.json  (board_dir, roots).
Env overrides: AGENT_BOARD_DIR, AGENT_BOARD_ROOTS (colon-separated)."""
import sys, os, json, time, hashlib, glob

CFG_DIR = os.path.expanduser("~/.config/obsidian-agent-board")
POINTER_DIR = os.path.join(CFG_DIR, "pointers")
CURSOR_DIR = os.path.join(CFG_DIR, "inbox")
ORDER = ["status", "session", "session_id", "repo", "worktree", "branch",
         "task", "claims", "started", "updated"]


def load_config():
    cfg = {}
    try:
        with open(os.path.join(CFG_DIR, "config.json")) as f:
            cfg = json.load(f)
    except Exception:
        cfg = {}
    board = (os.environ.get("AGENT_BOARD_DIR") or cfg.get("board_dir")
             or os.path.expanduser("~/agent-board/sessions"))
    return os.path.expanduser(board)


BOARD = load_config()


def now_iso():
    return time.strftime("%Y-%m-%dT%H:%M:%S")


def read_note(path):
    with open(path) as f:
        text = f.read()
    parts = text.split("---\n")
    fm = {}
    if len(parts) >= 3:
        for line in parts[1].splitlines():
            if ":" not in line:
                continue
            k, v = line.split(":", 1)
            k, v = k.strip(), v.strip()
            if not k:
                continue
            if k == "claims":
                try: fm[k] = json.loads(v)
                except Exception: fm[k] = []
            elif k == "task":
                try: fm[k] = json.loads(v)
                except Exception: fm[k] = v
            else:
                fm[k] = v
        body = "---\n".join(parts[2:])
    else:
        body = ""
    return fm, body


def write_note(path, fm, body=""):
    lines = ["---"]
    for k in ORDER:
        if k not in fm:
            continue
        v = fm[k]
        if k == "claims":
            v = json.dumps(v, ensure_ascii=False)
        elif k == "task":
            v = json.dumps(v if v else "", ensure_ascii=False)
        lines.append(f"{k}: {v}")
    out = "\n".join(lines) + "\n---\n" + (body or "")
    tmp = path + ".tmp"
    with open(tmp, "w") as f:
        f.write(out)
    os.replace(tmp, path)


def load_active(exclude_sid=None):
    out = []
    for p in glob.glob(os.path.join(BOARD, "*.md")):
        if os.path.basename(p).startswith("_"):
            continue
        try:
            fm, _ = read_note(p)
        except Exception:
            continue
        if fm.get("status") != "active":
            continue
        if exclude_sid and fm.get("session_id") == exclude_sid:
            continue
        out.append(fm)
    return out


# --- messaging -----------------------------------------------------------
def msg_store(board):
    return os.path.join(board, ".messages.jsonl")


def mirror_path(board):
    return os.path.join(os.path.dirname(board), "Agent Chat.md")


def append_message(board, frm, frm_name, to, text):
    rec = {"ts": now_iso(), "from": frm, "from_name": frm_name, "to": to, "text": text}
    with open(msg_store(board), "a") as f:
        f.write(json.dumps(rec, ensure_ascii=False) + "\n")
    try:
        with open(mirror_path(board), "a") as f:
            f.write(f"- **{rec['ts'][11:16]} {frm_name} → {to}**: {text}\n")
    except Exception:
        pass


def read_messages(board):
    out = []
    try:
        with open(msg_store(board)) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    out.append(json.loads(line))
                except Exception:
                    pass
    except FileNotFoundError:
        pass
    return out


def deliver_for(board, sid, sid_name):
    msgs = read_messages(board)
    cp = os.path.join(CURSOR_DIR, sid)
    try:
        cur = int(open(cp).read().strip())
    except Exception:
        cur = 0
    mine = [m for m in msgs[cur:] if m.get("from") != sid
            and m.get("to") in (sid, sid_name, "all", "@all", "everyone")]
    os.makedirs(CURSOR_DIR, exist_ok=True)
    with open(cp, "w") as f:
        f.write(str(len(msgs)))
    return mine


def my_note():
    h = hashlib.sha1(os.path.realpath(os.getcwd()).encode()).hexdigest()
    ptr = os.path.join(POINTER_DIR, h)
    if not os.path.exists(ptr):
        sys.exit("agent-board: no session note for this cwd. Is the hook installed, "
                 "and is this dir in scope (a git repo, or under a configured root)?")
    with open(ptr) as f:
        sid = f.read().strip()
    note = os.path.join(BOARD, f"{sid}.md")
    if not os.path.exists(note):
        sys.exit(f"agent-board: pointer found but note missing: {note}")
    return sid, note


def cmd_task(args):
    _, note = my_note()
    fm, body = read_note(note)
    fm["task"] = " ".join(args)
    fm["updated"] = now_iso()
    write_note(note, fm, body)
    print(f"task set: {fm['task']}")


def cmd_claim(args):
    sid, note = my_note()
    fm, body = read_note(note)
    claims = fm.get("claims", [])
    for a in args:
        if a not in claims:
            claims.append(a)
    fm["claims"] = claims
    fm["updated"] = now_iso()
    write_note(note, fm, body)
    others = load_active(exclude_sid=sid)
    for a in args:
        for h in others:
            if any(a == c or a in c or c in a for c in h.get("claims", [])):
                print(f"⚠️  {a} ALSO claimed by {h.get('session')} "
                      f"({h.get('repo')}/{h.get('worktree')}): {h.get('task')}")
    print(f"claims: {fm['claims']}")


def cmd_release(args):
    _, note = my_note()
    fm, body = read_note(note)
    fm["claims"] = [c for c in fm.get("claims", []) if c not in args]
    fm["updated"] = now_iso()
    write_note(note, fm, body)
    print(f"claims: {fm['claims']}")


def cmd_note(args):
    _, note = my_note()
    fm, body = read_note(note)
    body = (body or "").rstrip() + f"\n- {now_iso()} {' '.join(args)}\n"
    fm["updated"] = now_iso()
    write_note(note, fm, body)
    print("logged.")


def cmd_check(args):
    if not args:
        sys.exit("usage: agent-board check <path>")
    target = args[0]
    sid, _ = my_note()
    hits = []
    for o in load_active(exclude_sid=sid):
        for c in o.get("claims", []):
            if target == c or target in c or c in target \
                    or os.path.basename(c) == os.path.basename(target):
                hits.append((o, c))
    if not hits:
        print(f"clear: no live session claims {target}")
        return
    for o, c in hits:
        print(f"⚠️  {target} claimed via '{c}' by {o.get('session')} "
              f"({o.get('repo')}/{o.get('worktree')}): {o.get('task')}")


def cmd_who(_args):
    rows = load_active()
    if not rows:
        print("no active sessions.")
        return
    for o in sorted(rows, key=lambda r: (r.get("repo", ""), r.get("worktree", ""))):
        cl = ", ".join(os.path.basename(c) for c in o.get("claims", [])) or "-"
        print(f"[{o.get('repo')}/{o.get('worktree')}] {o.get('session')}: "
              f"{o.get('task')}  | claims: {cl}")


def cmd_where(_args):
    print("board dir:", BOARD)
    try:
        _, note = my_note()
        print("your note:", note)
    except SystemExit as e:
        print(e)


def cmd_msg(args):
    if len(args) < 2:
        sys.exit('usage: agent-board msg <session|all> "<text>"')
    sid, note = my_note()
    fm, _ = read_note(note)
    to, text = args[0], " ".join(args[1:])
    append_message(BOARD, sid, fm.get("session", sid[:8]), to, text)
    if to not in ("all", "@all", "everyone"):
        if not any(to in (o.get("session"), o.get("session_id")) for o in load_active()):
            print(f"(no ACTIVE session matches '{to}' — it'll wait in the log for them)")
    print(f"sent to {to}.")


def cmd_inbox(_args):
    sid, note = my_note()
    fm, _ = read_note(note)
    mine = deliver_for(BOARD, sid, fm.get("session", sid[:8]))
    if not mine:
        print("inbox empty.")
        return
    for m in mine:
        print(f"[{m.get('ts', '')[11:16]}] {m.get('from_name')} → "
              f"{m.get('to')}: {m.get('text')}")


PAGE = """<!doctype html><html lang="en"><head><meta charset="utf-8">
<title>Agent Board</title>
<style>
 :root{color-scheme:dark}
 *{box-sizing:border-box}
 body{margin:0;background:#0d1117;color:#e6edf3;font:14px/1.5 -apple-system,Segoe UI,Roboto,sans-serif}
 header{padding:13px 20px;border-bottom:1px solid #21262d;display:flex;align-items:center;gap:11px}
 header h1{font-size:15px;margin:0;font-weight:600}
 .dot{width:8px;height:8px;border-radius:50%;background:#3fb950;box-shadow:0 0 8px #3fb950}
 .muted{color:#7d8590;font-size:12px}
 .wrap{display:grid;grid-template-columns:1.3fr 1fr;height:calc(100vh - 49px)}
 .col{padding:16px 20px;overflow:auto}
 .col+.col{border-left:1px solid #21262d}
 h2{font-size:11px;text-transform:uppercase;letter-spacing:.09em;color:#7d8590;margin:0 0 12px}
 table{width:100%;border-collapse:collapse}
 th,td{text-align:left;padding:8px 10px;border-bottom:1px solid #21262d;vertical-align:top}
 th{font-size:11px;color:#7d8590;text-transform:uppercase;letter-spacing:.05em}
 .tag{display:inline-block;padding:1px 7px;border-radius:10px;background:#1f6feb22;color:#58a6ff;font-size:12px;font-variant-numeric:tabular-nums}
 .wt{color:#d29922}
 .idle{color:#7d8590;font-variant-numeric:tabular-nums;white-space:nowrap}
 .stale{color:#f85149}
 .claims{color:#a5d6ff;font-size:12px}
 .msg{padding:7px 0;border-bottom:1px solid #161b22}
 .msg .t{color:#6e7681;font-size:11px;margin-right:7px;font-variant-numeric:tabular-nums}
 .msg .from{color:#58a6ff;font-weight:600}
 .msg .to{color:#7d8590}
 .empty{color:#7d8590;font-style:italic;padding:18px 0}
</style></head><body>
<header><span class="dot"></span><h1>Agent Board</h1><span class="muted" id="meta"></span></header>
<div class="wrap">
 <div class="col"><h2>Live sessions</h2><div id="sessions"></div></div>
 <div class="col"><h2>Conversations</h2><div id="chat"></div></div>
</div>
<script>
function el(t,c,txt){var e=document.createElement(t);if(c)e.className=c;if(txt!=null)e.textContent=txt;return e;}
function idleStr(m){return m>=60?(Math.floor(m/60)+'h '+(m%60)+'m'):(m+'m');}
async function tick(){
 try{
  var d=await (await fetch('/data',{cache:'no-store'})).json();
  document.getElementById('meta').textContent=d.sessions.length+' active \\u00b7 updated '+d.generated;
  var S=document.getElementById('sessions');S.innerHTML='';
  if(!d.sessions.length){S.appendChild(el('div','empty','No active sessions.'));}
  else{
   var tbl=el('table'),hr=el('tr');['Session','Repo / worktree','Working on','Claims','Idle'].forEach(function(h){hr.appendChild(el('th',null,h));});tbl.appendChild(hr);
   d.sessions.forEach(function(s){
    var tr=el('tr'),td=el('td');td.appendChild(el('span','tag',s.session));tr.appendChild(td);
    var loc=el('td');loc.appendChild(el('span',null,s.repo));loc.appendChild(document.createTextNode(' / '));loc.appendChild(el('span','wt',s.worktree));tr.appendChild(loc);
    tr.appendChild(el('td',null,s.task||'\\u2014'));
    tr.appendChild(el('td','claims',(s.claims&&s.claims.length)?s.claims.map(function(c){return c.split('/').pop();}).join(', '):'\\u2014'));
    tr.appendChild(el('td',s.idle>=720?'idle stale':'idle',idleStr(s.idle)));
    tbl.appendChild(tr);
   });
   S.appendChild(tbl);
  }
  var C=document.getElementById('chat');C.innerHTML='';
  if(!d.messages.length){C.appendChild(el('div','empty','No messages yet \\u2014 agents send with: agent-board msg <session|all> "\\u2026"'));}
  else{
   d.messages.forEach(function(m){
    var div=el('div','msg');
    div.appendChild(el('span','t',(m.ts||'').slice(11,16)));
    div.appendChild(el('span','from',m.from_name||m.from||'?'));
    div.appendChild(el('span','to',' \\u2192 '+(m.to||'?')+': '));
    div.appendChild(document.createTextNode(m.text||''));
    C.appendChild(div);
   });
   C.scrollTop=C.scrollHeight;
  }
 }catch(e){document.getElementById('meta').textContent='disconnected (server stopped?)';}
}
tick();setInterval(tick,2000);
</script></body></html>"""


def cmd_serve(args):
    import http.server
    import glob as _glob
    port = int(args[0]) if args and args[0].lstrip("-").isdigit() else 7900

    def snapshot():
        sessions = []
        for p in _glob.glob(os.path.join(BOARD, "*.md")):
            if os.path.basename(p).startswith("_"):
                continue
            try:
                fm, _ = read_note(p)
            except Exception:
                continue
            if fm.get("status") != "active":
                continue
            try:
                idle = int((time.time() - os.path.getmtime(p)) / 60)
            except Exception:
                idle = 0
            sessions.append({"session": fm.get("session", ""), "repo": fm.get("repo", ""),
                             "worktree": fm.get("worktree", ""), "task": fm.get("task", ""),
                             "claims": fm.get("claims", []), "idle": idle})
        sessions.sort(key=lambda s: (s["repo"], s["session"]))
        msgs = []
        try:
            with open(msg_store(BOARD)) as f:
                for line in f:
                    line = line.strip()
                    if line:
                        try:
                            msgs.append(json.loads(line))
                        except Exception:
                            pass
        except FileNotFoundError:
            pass
        return {"sessions": sessions, "messages": msgs[-60:],
                "generated": time.strftime("%H:%M:%S")}

    class H(http.server.BaseHTTPRequestHandler):
        def log_message(self, *a):
            pass

        def _send(self, body, ctype):
            self.send_response(200)
            self.send_header("Content-Type", ctype)
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)

        def do_GET(self):
            if self.path.startswith("/data"):
                self._send(json.dumps(snapshot()).encode(), "application/json")
            else:
                self._send(PAGE.encode(), "text/html; charset=utf-8")

    try:
        httpd = http.server.ThreadingHTTPServer(("127.0.0.1", port), H)
    except OSError as e:
        sys.exit(f"agent-board serve: can't bind port {port} ({e}). Try a different port: agent-board serve 7901")
    print(f"agent-board dashboard → http://127.0.0.1:{port}   (Ctrl-C to stop)")
    print(f"board: {BOARD}")
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print("\\nstopped.")


CMDS = {"task": cmd_task, "claim": cmd_claim, "release": cmd_release,
        "note": cmd_note, "check": cmd_check, "who": cmd_who, "where": cmd_where,
        "msg": cmd_msg, "inbox": cmd_inbox, "serve": cmd_serve}


def main():
    if len(sys.argv) < 2 or sys.argv[1] not in CMDS:
        sys.exit(__doc__)
    CMDS[sys.argv[1]](sys.argv[2:])


if __name__ == "__main__":
    main()
